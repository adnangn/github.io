            100% { background-color: rgba(16, 185, 129, 0.10); box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.00); }
        }

        .pulse-effect {
            animation: pulse-green 2s ease-in-out infinite;
            font-weight: 700;
            border-radius: 6px;
            padding: 2px 4px;
            background: rgba(16, 185, 129, 0.12);
        }

        ::selection {
            background: rgba(37, 99, 235, 0.16);
            color: #0f172a;
        }

        .panel-editor::-webkit-scrollbar,
        .panel-preview::-webkit-scrollbar,
        .panel-audit::-webkit-scrollbar {
            width: 10px;
            height: 10px;
        }

        .panel-editor::-webkit-scrollbar-thumb,
        .panel-preview::-webkit-scrollbar-thumb,
        .panel-audit::-webkit-scrollbar-thumb {
            background: rgba(15, 23, 42, 0.18);
            border-radius: 999px;
            border: 3px solid transparent;
            background-clip: content-box;
        }

        .panel-editor::-webkit-scrollbar-track,
        .panel-preview::-webkit-scrollbar-track,
        .panel-audit::-webkit-scrollbar-track {
            background: transparent;
        }

        @media (max-width: 1280px) {
            body {
                overflow: auto;
            }

            .header {
                margin: 12px 12px 0;
            }

            .main {
                flex-direction: column;
                padding: 12px;
                overflow: visible;
            }

            .panel-editor,
            .panel-audit {
                width: 100%;
                min-width: 0;
            }

            .panel-preview {
                min-height: 60vh;
            }
        }

        @media (max-width: 900px) {
            .header {
                flex-direction: column;
                align-items: stretch;
            }

            .header-actions {
                justify-content: flex-start;
            }

            .header-title {
                font-size: 17px;
            }

            .panel-preview {
                padding: 12px;
            }

            #render-wrapper {
                padding: 18px;
                border-radius: 22px;
            }
        }
    </style>
</head>
<body>

<div class="header">
    <div class="header-brand">
        <div class="header-title">GİB XSLT Renderer + YTB Denetim Motoru</div>
        <div class="header-subtitle">XML yükle, denetle ve çıktıyı sade bir görünümle izle</div>
    </div>
    <div class="header-actions">
        <span id="scaleStatus" class="status">Sistem Bekleniyor...</span>
        <button id="toggleAudit">Denetim Paneli</button>
        <button id="printButton" onclick="window.print()">Yazdır / PDF</button>
    </div>
</div>

<div class="main">
    <div class="panel-editor" id="dropZone">
        <div class="file-upload-bar">
            <label for="fileInput" class="file-upload-label">📁 XML Dosyası Seç</label>
            <span class="upload-hint">veya buraya sürükle</span>
            <input type="file" id="fileInput" accept=".xml" style="display:none;">
        </div>
        <textarea id="xmlInput" placeholder="UBL-TR XML Kodunu Buraya Yapıştırın veya Dosyayı Sürükleyin..." oninput="processInvoice()"></textarea>
    </div>

    <div class="panel-preview">
        <div id="render-wrapper">
            <div id="invoiceContent">
                <div class="empty-state">
                    <h2>Sistem Hazır</h2>
                    <p>XML dosyasını sol panele sürükleyin veya kodu yapıştırın.</p>
                </div>
            </div>
        </div>
    </div>

    <div class="panel-audit">
        <div class="audit-header">YTB DENETİM PANELİ</div>
        <details class="audit-section audit-collapse">
            <summary class="audit-summary">
                <div class="audit-title">1. METİN KONTROLÜ</div>
                <span class="audit-summary-meta">Açık / Kapat</span>
            </summary>
            <div class="audit-collapse-body">
                <div id="audit-found"></div>
                <div id="audit-missing" class="audit-missing"></div>
            </div>
        </details>
        <div class="audit-section">
            <div class="audit-title">2. KDV 13/d KONTROLÜ</div>
            <div id="audit-math-result" class="audit-math-result">XML bekleniyor...</div>
            <div id="audit-math-details" class="details-box"></div>
        </div>
    </div>
</div>

<script>
    const AUDIT_KEYWORDS = ['YATIRIMTEŞVİK', 'YATIRIM', 'YATİRİM', 'İSTİSNA', 'ISTISNA', 'Tesvşk', 'Teşvik', '3065 sayılı', '13/d', 'YTB'];
    const REQUIRED_KEYWORDS = ['Yeni', 'Kullanılmamış', 'KUllanılmamış']; // "Kullanılmamıştır" kök kelimeye indirgendi.

    // 1. KUSURSUZ ARAMA NORMALİZATÖRÜ (Tüm boşlukları, tireleri ve Türkçe harfleri düzleştirir)
    function normalizeForSearch(text) {
        if (!text) return "";
        return text.replace(/i/g, 'İ')
                   .replace(/ı/g, 'I')
                   .toLocaleUpperCase('tr-TR')
                   .replace(/Ş/g, 'S')
                   .replace(/Ç/g, 'C')
                   .replace(/Ğ/g, 'G')
                   .replace(/Ö/g, 'O')
                   .replace(/Ü/g, 'U')
                   .replace(/İ/g, 'I')
                   .replace(/[\s\-\_\/]/g, ''); // Tüm boşluk ve sembolleri yutar
    }

    function escapeRegExp(string) {
        return string.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    }

    // 2. GÖRSEL VURGULAMA İÇİN ESNETİLMİŞ REGEX (Araya giren boşlukları tolere eder)
    function createTrRegex(word) {
        const cleanWord = word.replace(/[\s\-\/]/g, ''); 
        let pattern = '';
        for (let i = 0; i < cleanWord.length; i++) {
            let char = cleanWord[i].toUpperCase();
            if (i > 0) pattern += '[\\s\\-\\/]*'; // Harflerin arasına opsiyonel boşluk/tire girebilir
            
            if (char === 'I' || char === 'İ') pattern += '[iİıI]';
            else if (char === 'S' || char === 'Ş') pattern += '[sSşŞ]';
            else if (char === 'C' || char === 'Ç') pattern += '[cCçÇ]';
            else if (char === 'G' || char === 'Ğ') pattern += '[gGğĞ]';
            else if (char === 'O' || char === 'Ö') pattern += '[oOöÖ]';
            else if (char === 'U' || char === 'Ü') pattern += '[uUüÜ]';
            else pattern += escapeRegExp(char); 
        }
        // Sadece düz metinlerde (HTML etiketlerinin dışında) arama yap
        return new RegExp(`(?![^<]*>)(${pattern})`, 'gi'); 
    }

    const dropZone = document.getElementById('dropZone');
    const fileInput = document.getElementById('fileInput');
    const xmlInput = document.getElementById('xmlInput');
    const toggleAuditBtn = document.getElementById('toggleAudit');
    const panelAudit = document.querySelector('.panel-audit');

    toggleAuditBtn.addEventListener('click', () => {
        panelAudit.classList.toggle('hidden');
        toggleAuditBtn.textContent = panelAudit.classList.contains('hidden') ? 'Denetim Panelini Aç' : 'Denetim Paneli';
    });

    dropZone.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.classList.add('dragover'); });
    dropZone.addEventListener('dragleave', () => { dropZone.classList.remove('dragover'); });
    dropZone.addEventListener('drop', (e) => {
        e.preventDefault();
        dropZone.classList.remove('dragover');
        if (e.dataTransfer.files.length > 0) handleFile(e.dataTransfer.files[0]);
    });

    fileInput.addEventListener('change', (e) => {
        if (e.target.files.length > 0) handleFile(e.target.files[0]);
    });

    function handleFile(file) {
        if (file.type !== "text/xml" && !file.name.toLowerCase().endsWith('.xml')) {
            alert("Lütfen geçerli bir XML (.xml) dosyası yükleyin.");
            return;
        }
        const reader = new FileReader();
        reader.onload = (e) => { xmlInput.value = e.target.result; processInvoice(); };
        reader.onerror = () => { alert("Dosya okunurken bir hata oluştu."); };
        reader.readAsText(file);
    }

    function getXmlValue(xmlDoc, tagName) {
        const nodes = xmlDoc.getElementsByTagNameNS("*", tagName);
        return nodes.length > 0 ? nodes[0].textContent.trim() : "0";
    }

    async function processInvoice() {
        let xmlText = xmlInput.value.trim();
        const container = document.getElementById('invoiceContent');
        const statusText = document.getElementById('scaleStatus');
        
        if (!xmlText) return;

        xmlText = xmlText.replace(/This XML file does not appear to have any style information associated with it\. The document tree is shown below\./g, '');

        try {
            const parser = new DOMParser();
            const xmlDoc = parser.parseFromString(xmlText, "text/xml");
            
            if (xmlDoc.getElementsByTagName("parsererror").length > 0) {
                statusText.innerText = "Hata: Geçersiz XML Formatı!";
                return;
            }

            const xsltNode = xmlDoc.getElementsByTagNameNS("*", "EmbeddedDocumentBinaryObject")[0];
            if (xsltNode) {
                const arr = Uint8Array.from(atob(xsltNode.textContent.trim()), c => c.charCodeAt(0));
                const utf8Xslt = new TextDecoder("utf-8").decode(arr);
                const xsltDoc = parser.parseFromString(utf8Xslt, "text/xml");

                const processor = new XSLTProcessor();
                processor.importStylesheet(xsltDoc);
                const resultFragment = processor.transformToFragment(xmlDoc, document);

                container.innerHTML = "";
                container.appendChild(resultFragment);

                let htmlContent = container.innerHTML;
                [...AUDIT_KEYWORDS, ...REQUIRED_KEYWORDS].forEach(word => {
                    const regex = createTrRegex(word);
                    htmlContent = htmlContent.replace(regex, `<span class="pulse-effect">$1</span>`);
                });
                container.innerHTML = htmlContent;

                statusText.innerText = "Orijinal GİB Şablonu Yüklendi (Yazdırmaya Hazır)";
            } else {
                container.innerHTML = `<div style="padding:20px; color:red;">Hata: XML içinde XSLT şablonu bulunamadı.</div>`;
            }

            // 3. DAHA DERİN TARAMA (Description ve TaxExemptionReason eklendi)
            let fullText = "";
            const searchTags = ["Note", "Name", "Description", "TaxExemptionReason"];
            searchTags.forEach(tag => {
                const nodes = xmlDoc.getElementsByTagNameNS("*", tag);
                for (let node of nodes) fullText += " " + node.textContent;
            });

            // Metni boşluksuz ve harf toleranslı hale getir
            const searchBaseText = normalizeForSearch(fullText);
            
            let found = new Set();
            let missing = [];

            [...AUDIT_KEYWORDS, ...REQUIRED_KEYWORDS].forEach(word => {
                const searchWord = normalizeForSearch(word);
                // "YATIRIMTEŞVİK" kelimesi artık searchBaseText içinde kesinlikle yakalanacak.
                if (searchBaseText.includes(searchWord)) {
                    found.add(word);
                } else {
                    missing.push(word);
                }
            });

            document.getElementById("audit-found").innerHTML = [...found].map(w => `<div class="found-item">✔ ${w}</div>`).join('');
            document.getElementById("audit-missing").innerHTML = missing.map(w => `<div class="missing-item">✖ ${w}</div>`).join('');

            const hasBoth = found.has("Yeni") && found.has("Kullanılmamış");
            if (!hasBoth) {
                document.getElementById("audit-missing").innerHTML += `<div style="color:#e74c3c; font-weight:bold; margin-top:10px; border-top:1px solid #e74c3c; padding-top:5px;">KRİTİK UYARI:<br>'Yeni' ve 'Kullanılmamış' şartı eksik!</div>`;
            }

            const extAmtStr = getXmlValue(xmlDoc, "LineExtensionAmount"); 
            const payAmtStr = getXmlValue(xmlDoc, "PayableAmount"); 
            
            const taxNodes = xmlDoc.getElementsByTagNameNS("*", "TaxTotal");
            let totalTaxAmt = 0;
            if(taxNodes.length > 0) {
                totalTaxAmt = parseFloat(taxNodes[0].getElementsByTagNameNS("*", "TaxAmount")[0]?.textContent || 0);
            }

            const malHizmet = parseFloat(extAmtStr || 0);
            const odenecek = parseFloat(payAmtStr || 0);

            const mathRes = document.getElementById("audit-math-result");
            const mathDetails = document.getElementById("audit-math-details");

            mathDetails.innerHTML = `Mal Hizmet: ${malHizmet.toFixed(2)}<br>Hesaplanan KDV: ${totalTaxAmt.toFixed(2)}<br>Ödenecek Tutar: ${odenecek.toFixed(2)}`;

            let isYTB = AUDIT_KEYWORDS.some(w => found.has(w));

            if (isYTB) {
                if (Math.abs((malHizmet + totalTaxAmt) - odenecek) < 0.02 && totalTaxAmt > 0) {
                    mathRes.innerHTML = `<div class="alert-box">KRİTİK HATA!<br>Hesaplanan KDV tutarı, Ödenecek Tutara DAHİL EDİLMİŞTİR!</div>`;
                } 
                else if (Math.abs(malHizmet - odenecek) < 0.02) {
                    mathRes.innerHTML = `<div class="success-box">✔ MATEMATİK DOĞRU<br>KDV, Ödenecek Tutara yansıtılmamış.</div>`;
                } 
                else {
                    mathRes.innerHTML = `<div style="color:#f1c40f; padding: 10px; border: 1px solid #f1c40f; margin-top: 10px;">DİKKAT<br>Tutar uyuşmazlığı var. Tevkifat/İskonto kontrol edilmeli.</div>`;
                }
            } else {
                mathRes.innerHTML = `<span style="color:#aaa;">Faturada Teşvik ibaresi bulunmadığı için matematik kontrolü atlandı.</span>`;
            }

        } catch (e) {
            statusText.innerText = "Hata oluştu.";
            console.error(e);
        }
    }
</script>

</body>
</html>
